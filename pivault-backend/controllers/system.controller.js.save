const os = require("os");
const { execSync } = require("child_process");

exports.getSystemInfo = (req, res) => {
    try {
        const cpus = os.cpus();
        const nets = os.networkInterfaces();

        let lanIP = "Not Found";
        let tailscaleIP = "Not Found";
        let cpuTemp = "Not Available";

        // ✅ LAN IP (STRICT FILTER: eth0 / wlan0 only)
        for (const name of Object.keys(nets)) {
            for (const net of nets[name]) {
                if (
                    net.family === "IPv4" &&
                    !net.internal &&
                    (name === "eth0" || name === "wlan0")
                ) {
                    lanIP = net.address;
                }
            }
        }

        // ✅ TAILSCALE IP (BEST METHOD)
        try {
            const tsIP = execSync("tailscale ip -4").toString().trim();
            if (tsIP) {
                tailscaleIP = tsIP;
            }
        } catch (err) {
            console.log("Tailscale not running");
        }

        // ✅ CPU TEMPERATURE (Raspberry Pi)
        try {
    // Use shell explicitly (fix PATH issue)
    const tempRaw = execSync("vcgencmd measure_temp", { shell: "/bin/bash" }).toString();

    console.log("RAW TEMP:", tempRaw);

    const match = tempRaw.match(/temp=([\d.]+)'C/);

    if (match && match[1]) {
        cpuTemp = `${match[1]} °C`;
    } else {
        cpuTemp = "Parse Error";
    }


}
 catch (err) {
    console.log("CPU TEMP ERROR:", err.message);
    cpuTemp = "Not Available";
}

        res.json({
            cpuModel: cpus[0].model,
            ramUsage: `${((os.totalmem() - os.freemem()) / (1024 ** 3)).toFixed(2)} GB / ${(os.totalmem() / (1024 ** 3)).toFixed(2)} GB`,
            uptime: `${Math.floor(os.uptime() / 60)} minutes`,
            platform: os.platform(),
            lanIP,
            tailscaleIP,
            cpuTemp
        });

    } catch (err) {
        console.error("System Info Error:", err);
        res.status(500).json({ message: "Er
